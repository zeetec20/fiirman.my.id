# --------------------------------------------------------------------
# .env.example — committed template. Copy to .env (gitignored) for local
# dev; set the same keys in Cloudflare for production.
# --------------------------------------------------------------------

# Supabase (browser-exposed — anon key is safe to expose; RLS protects data)
# Used by src/lib/supabase.ts for client-side analytics RPC.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --------------------------------------------------------------------
# Deployment notes (Cloudflare Workers)
# --------------------------------------------------------------------
# VITE_* vars are inlined into the client bundle at BUILD time, not
# runtime. The build must run with these vars set in its environment.
#
# Options:
#   (a) Build locally before `wrangler deploy` — `.env` is read by Vite.
#   (b) Build in CI (GitHub Actions, etc.) — set the vars as repo
#       secrets and export them before `bun run build`.
#   (c) Cloudflare Pages-style build (if using the dashboard build
#       pipeline) — set the vars in the project's Build env settings.
#
# Cloudflare Worker runtime "Variables and Secrets" (set via the
# dashboard or `wrangler secret put`) will NOT reach VITE_* — those
# only feed `env.<NAME>` inside the Worker handler, not the client
# bundle.
