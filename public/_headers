# Cloudflare static-assets cache rules.
# Vite copies /public/_headers verbatim into dist/client/, and Wrangler
# Static Assets honors the standard Netlify-style _headers syntax.
#
# Hashed Vite chunks live under /assets/ — immutable forever.
# Self-hosted fonts have content-hashed filenames — also immutable.
# Per-article images and the placeholder folder mutate occasionally; 30d.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=2592000

/article/*
  Cache-Control: public, max-age=2592000

/favicon.svg
  Cache-Control: public, max-age=604800

/favicon.ico
  Cache-Control: public, max-age=604800

/manifest.json
  Cache-Control: public, max-age=604800

/robots.txt
  Cache-Control: public, max-age=604800
